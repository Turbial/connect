SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Phase 10: agent-facing HTTP API (src/agent-api) — any agent (Claude or
# otherwise) calling POST /tools/:name needs this exact bearer token.
# Requests are rejected outright if this is unset (fails closed, never open).
# Phase 15 security hardening: also required as a Bearer token on every
# /businesses/:id/* and /organizations/:id/* route in src/index.ts, since a
# UUID alone is not a valid trust boundary for operator data/state changes.
CONNECT_AGENT_API_KEY=
AGENT_API_PORT=8787

# Google Business Profile (Business Information + Posts + Performance APIs)
GBP_CLIENT_ID=
GBP_CLIENT_SECRET=

# Twilio — two-way SMS approval (no equivalent exists in Reach toolkit, built fresh here)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Phase 15 security hardening: the exact public URL Twilio calls for webhooks
# (e.g. https://connect.example.com) — required to verify the X-Twilio-Signature
# header on /webhooks/sms and /webhooks/missed-call. Requests are rejected
# outright if TWILIO_AUTH_TOKEN or this is unset (fails closed, never open).
WEBHOOK_BASE_URL=

# Phase 15 security hardening: shared secret Reach must send as a Bearer
# token on POST /webhooks/reach-review. Requests are rejected outright if
# this is unset (fails closed, never open).
REACH_WEBHOOK_SECRET=

# Phase 16: Stripe webhook signing secret for POST /webhooks/stripe (revenue
# attribution into lead_event on checkout.session.completed — set the
# business id as the Checkout session's client_reference_id). Requests are
# rejected outright if this is unset (fails closed, never open).
STRIPE_WEBHOOK_SECRET=

# Phase 16: shared secret any CRM/form/booking system must send as a Bearer
# token on POST /webhooks/crm to attribute a lead into lead_event. Requests
# are rejected outright if this is unset (fails closed, never open).
CRM_WEBHOOK_SECRET=

# Content Engine generation backends (mirrors TurboAd's pattern: DeepSeek for copy, fal.ai for images)
DEEPSEEK_API_KEY=
FAL_API_KEY=

# Reach email reuse (Winnr/EmailJS/Zoho — whichever Reach is configured with)
REACH_EMAIL_WEBHOOK_URL=

# Default approval timeout before auto-post/auto-hold, in hours
APPROVAL_TIMEOUT_HOURS=48

# Meta Graph/Marketing API (Facebook Page + Instagram posting, Phase 2; ad campaign launch, Phase 3)
# Per-business fb_page_access_token/meta_ads_account_id live in the business table, not here —
# these are only needed if a server-side app-level token is required for token refresh flows.
META_APP_ID=
META_APP_SECRET=

# Google Ads API (paid boost campaign launch, Phase 3)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=

# Pinterest, X, LinkedIn posting (Phase 5)
# Per-business pinterest_access_token/twitter_access_token/linkedin_access_token
# live in the business table; these are only the app-level OAuth credentials
# needed to obtain those per-business tokens during onboarding.
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Threads, Yelp, Nextdoor, Snapchat posting (Phase 6)
# Per-business *_access_token columns live in the business table; these are
# the app-level OAuth credentials needed to obtain those tokens during
# onboarding. Yelp and Nextdoor require partner program approval before
# these credentials are issued — same lead-time caveat as GBP/Google Ads.
THREADS_APP_ID=
THREADS_APP_SECRET=
YELP_CLIENT_ID=
YELP_CLIENT_SECRET=
NEXTDOOR_CLIENT_ID=
NEXTDOOR_CLIENT_SECRET=
SNAPCHAT_CLIENT_ID=
SNAPCHAT_CLIENT_SECRET=

# TikTok, YouTube posting (Phase 7, video platforms)
# Per-business tiktok_access_token/youtube_refresh_token live in the business
# table; these are the app-level OAuth credentials needed to obtain those
# tokens during onboarding. YouTube reuses the Google OAuth app credential
# pattern already used for Google Ads (see googleAds.ts's getAccessToken()).
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# WhatsApp, Reddit, Bluesky, Mastodon, Tumblr, WeChat posting (Phase 8)
# Per-business *_access_token columns live in the business table; these are
# the app-level OAuth credentials needed to obtain those tokens during
# onboarding. Bluesky uses per-business app passwords instead of OAuth
# (see bluesky.ts), so it has no app-level credential here. Mastodon is
# federated, so its per-business instance URL (mastodon_instance_url) lives
# in the business table rather than a single shared app credential.
WHATSAPP_APP_ID=
WHATSAPP_APP_SECRET=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
TUMBLR_CONSUMER_KEY=
TUMBLR_CONSUMER_SECRET=
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# Competitor monitoring (Phase 10 service module expansion)
# Used by src/competitor-monitor to pull rating/review-count snapshots for
# tracked competitors via the Places API (New) Place Details endpoint.
GOOGLE_PLACES_API_KEY=

# Telegram, Discord, Medium, VK, LINE, Vimeo, Flickr posting (Phase 11)
# Per-business *_access_token columns live in the business table; these are
# the app-level OAuth credentials needed to obtain those tokens during
# onboarding. Telegram bot tokens are generated per-business via @BotFather
# (no app-level client id/secret exists), so it has no entry here. Medium
# deprecated public OAuth app registration in favor of per-business
# integration tokens, so it also has no app-level secret here.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
VK_CLIENT_ID=
VK_CLIENT_SECRET=
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
VIMEO_CLIENT_ID=
VIMEO_CLIENT_SECRET=
FLICKR_API_KEY=
FLICKR_API_SECRET=

# Foursquare, Bing Places, Apple Business Connect, Houzz, Angi, Thumbtack,
# Tripadvisor, OpenTable, Quora, Trustpilot, Yandex Business posting
# (Phase 11, directory/listing/review platforms)
# Per-business *_access_token columns live in the business table; these are
# the app-level credentials needed to obtain those tokens during onboarding.
# Auth model varies widely across these platforms — see README Known gaps.
FOURSQUARE_CLIENT_ID=
FOURSQUARE_CLIENT_SECRET=
BING_CLIENT_ID=
BING_CLIENT_SECRET=
# Apple Business Connect uses cert-based auth (a private key signed with a
# team id/key id pair) rather than client id/secret OAuth.
APPLEBUSINESS_TEAM_ID=
APPLEBUSINESS_KEY_ID=
HOUZZ_CLIENT_ID=
HOUZZ_CLIENT_SECRET=
# Angi is a partner API; access (and credentials) are granted manually
# rather than through self-serve OAuth app registration.
ANGI_CLIENT_ID=
ANGI_CLIENT_SECRET=
THUMBTACK_CLIENT_ID=
THUMBTACK_CLIENT_SECRET=
# Tripadvisor's Content API uses a simple API key, not full OAuth.
TRIPADVISOR_API_KEY=
OPENTABLE_CLIENT_ID=
OPENTABLE_CLIENT_SECRET=
QUORA_CLIENT_ID=
QUORA_CLIENT_SECRET=
TRUSTPILOT_API_KEY=
TRUSTPILOT_API_SECRET=
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

# Phase 12's 72 new platforms (Weibo, Xiaohongshu, Douyin, KakaoTalk, Signal,
# Viber, Slack, Substack, WordPress, Etsy, Shopify, DoorDash, Airbnb, Waze,
# and the rest — see src/distribution/genericAdapter.ts for the full list)
# have no app-level credentials here because they route through a generic
# stub adapter rather than a real per-platform integration (see README's
# Known gaps). Per-business *_id/*_access_token columns already exist on
# `business` for all 72 so onboarding can store real values once each
# platform's actual API/auth model is confirmed and a bespoke adapter
# replaces the stub.
